# Example Caddy v2 config — TLS termination in front of ga4gh-infra Compose stack.
# Replace example.org hostnames and ensure Compose services are reachable at 127.0.0.1:808x
# (or use Docker network IP / host.docker.internal).
#
# Usage:
#   caddy run --config Caddyfile.example
#
# Caddy obtains Let's Encrypt certificates automatically when using public DNS.

aai.example.org {
	encode gzip
	reverse_proxy 127.0.0.1:8080
}

visas.example.org {
	encode gzip
	# Restrict to institute network in production (VPN, allowlist, or internal-only DNS).
	reverse_proxy 127.0.0.1:8081
}

duo.example.org {
	encode gzip
	reverse_proxy 127.0.0.1:8082
}

registry.example.org {
	encode gzip
	reverse_proxy 127.0.0.1:8083
}

data.example.org {
	encode gzip
	reverse_proxy 127.0.0.1:8084
}
