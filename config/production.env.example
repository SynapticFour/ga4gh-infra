# Production environment template — copy to a secure location (never commit real values).
# Used with: docker compose --env-file config/production.env ...

# Container image prefix and version pins (see docs/versioning.md)
GA4GH_IMAGE_PREFIX=ghcr.io/SynapticFour
AAI_BROKER_VERSION=0.1.0
VISA_REGISTRY_VERSION=0.1.0
DUO_SERVICE_VERSION=0.1.0
SERVICE_REGISTRY_VERSION=0.1.0
SAMPLE_RESOURCE_VERSION=0.1.0

# PostgreSQL — use strong passwords; prefer managed Postgres in production
POSTGRES_USER=ga4gh_app
POSTGRES_PASSWORD=CHANGE_ME
REGISTRY_DATABASE_URL=postgres://ga4gh_app:CHANGE_ME@postgres:5432/visa_registry
SERVICE_REGISTRY_DATABASE_URL=postgres://ga4gh_app:CHANGE_ME@postgres:5432/service_registry

# Broker
BROKER_COOKIE_SECRET=CHANGE_ME_OPENSSL_RAND_BASE64_32
MY_INSTITUTE_CLIENT_SECRET=from-keycloak-or-entra-client

# Visa registry DAC bootstrap key (rotate after initial DAC onboarding)
REGISTRY_BOOTSTRAP_API_KEY=CHANGE_ME

# Service registry internal registration (not for public clients)
SERVICE_REGISTRY_REGISTRATION_KEY=CHANGE_ME
