# Africa-mode all-in-one configuration for Raspberry Pi and field labs.
# Usage:
#   ga4gh-infra all-in-one --config config/all-in-one.africa.toml --africa
# Or:
#   GA4GH_OFFLINE=1 ga4gh-infra all-in-one --config config/all-in-one.africa.toml

[africa]
offline_first = true
max_memory_mb = 512
embedded_mock_idp = true
mock_idp_host = "127.0.0.1"
mock_idp_port = 9000
data_dir = "~/.config/ga4gh-infra/data"
jwks_cache_ttl_seconds = 600

[broker.server]
host = "127.0.0.1"
port = 8180
external_url = "http://localhost:8180"
environment = "development"

[broker.signing]
private_key_pem = "{{CONFIG_DIR}}/secrets/broker_rs256.pem"
passport_lifetime_seconds = 3600
token_lifetime_seconds = 3600

[broker.session]
cookie_secret_env = "BROKER_COOKIE_SECRET"
session_lifetime_seconds = 600

[[broker.upstream_idps]]
name = "embedded-mock-idp"
issuer = "http://127.0.0.1:9000"
client_id = "ga4gh-broker"
client_secret_env = "MOCK_IDP_CLIENT_SECRET"
scopes = ["openid", "profile", "email"]

[broker.upstream_idps.claim_mapping]
sub = "sub"
email = "email"

[[broker.visa_sources]]
name = "local-registry"
url = "http://127.0.0.1:8181"

[broker.ads]
url = "http://127.0.0.1:8190"
sync_api_key_env = "ADS_DAC_API_KEY"

[visa_registry.server]
host = "127.0.0.1"
port = 8181
external_url = "http://localhost:8181"
environment = "development"

[visa_registry.signing]
private_key_pem = "{{CONFIG_DIR}}/secrets/registry_rs256.pem"
visa_lifetime_seconds = 86400

[visa_registry.database]
driver = "sqlite"
url = "sqlite://{{CONFIG_DIR}}/data/visa_registry.sqlite"

[visa_registry.auth]
bootstrap_api_key_env = "REGISTRY_BOOTSTRAP_API_KEY"

[duo_service.server]
host = "127.0.0.1"
port = 8182
external_url = "http://localhost:8182"
environment = "development"

[service_registry.server]
host = "127.0.0.1"
port = 8183
external_url = "http://localhost:8183"
environment = "development"
read_only = false

[service_registry.database]
driver = "sqlite"
url = "sqlite://{{CONFIG_DIR}}/data/service_registry.sqlite"

[service_registry.auth]
registration_api_key_env = "SERVICE_REGISTRY_REGISTRATION_KEY"

[access_decision_service.server]
host = "127.0.0.1"
port = 8190
external_url = "http://localhost:8190"
environment = "development"

[access_decision_service.database]
driver = "sqlite"
url = "sqlite://{{CONFIG_DIR}}/data/ads.sqlite"
auto_migrate = true

[access_decision_service.oidc]
jwks_cache_ttl_seconds = 600

[[access_decision_service.oidc.trusted_brokers]]
issuer = "http://localhost:8180"
jwks_uri = "http://localhost:8180/jwks.json"

[access_decision_service.auth]
bootstrap_api_key_env = "ADS_DAC_API_KEY"

[access_decision_service.visa_registry]
url = "http://127.0.0.1:8181"
api_key_env = "REGISTRY_BOOTSTRAP_API_KEY"
