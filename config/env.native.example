# Example environment for native `ga4gh-infra all-in-one`.
# Copy to ~/.config/ga4gh-infra/env and `source` before starting.
#
# Service registry requires PostgreSQL unless you use the Docker stacks (`just up`).

BROKER_COOKIE_SECRET=change-me-broker-cookie-secret
MOCK_IDP_CLIENT_SECRET=change-me-idp-client-secret
REGISTRY_BOOTSTRAP_API_KEY=change-me-visa-api-key
ADS_DAC_API_KEY=change-me-ads-api-key
ADS_DATABASE_URL=sqlite://{{CONFIG_DIR}}/ads.sqlite
SERVICE_REGISTRY_REGISTRATION_KEY=change-me-service-registry-key
SERVICE_REGISTRY_DATABASE_URL=postgres://ga4gh:ga4gh@127.0.0.1:5432/service_registry
